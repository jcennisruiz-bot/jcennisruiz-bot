import pyautogui
import customtkinter as ctk
import time
from pynput import keyboard




def on_press(key):
        global ON
        listener = keyboard.Listener(on_press=on_press)
        
        if key == keyboard.Key.esc:
            print("stopped")
            ON = not ON
