def hi():
    pyautogui.FAILSAFE = True
    pyautogui.PAUSE = 0.05
    time.sleep(2)
    P, Y = pyautogui.position()
    while True:
        pyautogui.moveTo(P + 10, Y)
        pyautogui.moveTo(P, Y)
        pyautogui.click()
