def spam():
    ON = True
    pyautogui.FAILSAFE = True
    print("started")
    test = pyautogui.prompt("what do you wanna repeat")
    NUM = int(pyautogui.prompt("amount? "))
    pyautogui.confirm("press Esc to stop")
    print("get ready!")
    time.sleep(5)

    while ON:
        for i in range (NUM):
            if not ON:
               break
            pyautogui.write(test + " ", interval=000.1)
            pyautogui.press("space")
ON = False
